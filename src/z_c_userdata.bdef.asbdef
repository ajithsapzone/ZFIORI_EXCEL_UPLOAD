projection;
strict ( 2 );
//use draft;
use side effects;

define behavior for Z_C_USERDATA alias user
{
  use create;
  use update;
  use delete;

  //  use action Edit;
  //  use action Activate;
  //  use action Prepare;
  //  use action Discard;
  //  use action Resume;


  use action DownloadExcel;
  use action UploadExcelData;

  use association _userdept { create; }
}

define behavior for z_c_userdept alias userdept
{
  use update;
  use delete;

  use association _user;
}